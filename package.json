{
  "name": "fintrack",
  "version": "1.0.0",
  "description": "Secure, local-first Desktop Expense & Investment Tracker",
  "author": "cyb3ritic",
  "repository": {
    "type": "git",
    "url": "https://github.com/cyb3ritic/fintrack.git"
  },
  "main": "dist-electron/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "esbuild src/main/index.ts src/main/preload.ts --bundle --platform=node --outdir=dist-electron --external:electron --external:better-sqlite3-multiple-ciphers --external:adm-zip",
    "dev": "concurrently \"npm run dev:renderer\" \"esbuild src/main/index.ts src/main/preload.ts --bundle --platform=node --outdir=dist-electron --external:electron --external:better-sqlite3-multiple-ciphers --external:adm-zip --watch\" \"wait-on tcp:127.0.0.1:5173 && electron .\"",
    "build:renderer": "tsc -p tsconfig.json && vite build",
    "build:electron": "esbuild src/main/index.ts src/main/preload.ts --bundle --platform=node --outdir=dist-electron --external:electron --external:better-sqlite3-multiple-ciphers --external:adm-zip --minify",
    "build": "npm run build:renderer && npm run build:electron",
    "rebuild": "electron-rebuild -f -w better-sqlite3-multiple-ciphers",
    "postinstall": "electron-rebuild -w better-sqlite3-multiple-ciphers",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "adm-zip": "^0.5.14",
    "better-sqlite3-multiple-ciphers": "^12.11.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/better-sqlite3": "^7.6.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.1",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.21.5",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.cyb3ritic.fintrack",
    "productName": "FinTrack",
    "directories": {
      "output": "dist-pack"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "FinTrack",
      "uninstallDisplayName": "FinTrack",
      "runAfterFinish": true,
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "cyb3ritic",
        "repo": "fintrack"
      }
    ]
  }
}
